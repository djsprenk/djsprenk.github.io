---
layout: layouts/base.njk
title: Previous Events
---

<h1>Previous Events</h1>

{% for group in events | previousEventsByYear %}
<h2>{{ group.year }}</h2>
<ul class="event-list">
  {% for event in group.events %}
  <li class="event-item">
    <span class="event-item-name">{% if event.url %}<a href="{{ event.url }}" target="_blank" rel="noopener">{{ event.name }}</a>{% else %}{{ event.name }}{% endif %}{% if event.note %} <em>— {{ event.note }}</em>{% endif %}</span>
    <span class="event-item-meta">{{ event.location }}</span>
  </li>
  {% endfor %}
</ul>
{% endfor %}

<h2>Milestones</h2>
{% for milestone in milestones | reverse %}
<h3>{{ milestone.year }}</h3>
<ul class="event-list">
  {% for achievement in milestone.achievements %}
  <li class="event-item">
    <span class="event-item-name">{{ achievement }}</span>
  </li>
  {% endfor %}
</ul>
{% endfor %}

<p><a href="/events/upcoming">View upcoming events &rarr;</a></p>

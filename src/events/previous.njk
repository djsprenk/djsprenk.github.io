---
layout: layouts/base.njk
title: Previous Events
---

<h1>Previous Events</h1>

{% set milestonesByYear = milestones | indexByYear %}
<div class="timeline">
  {% for group in events | previousEventsByYear %} {% set yearMilestone = milestonesByYear[group.year] %}
  <div class="timeline-year">
    <div class="timeline-year-label">{{ group.year }}</div>
    {% if yearMilestone %}
    <ul class="timeline-achievements">
      {% for achievement in yearMilestone.achievements %}
      <li class="timeline-achievement">{{ achievement }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    <ul class="timeline-events">
      {% for event in group.events %}
      <li class="timeline-event">
        <span class="timeline-event-name"
          >{% if event.url %}<a href="{{ event.url }}" target="_blank" rel="noopener">{{ event.name }}</a>{% else %}{{
          event.name }}{% endif %}{% if event.note %} <em>· {{ event.note }}</em>{% endif %}</span
        >
        <span class="timeline-event-meta">{{ event.location }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</div>

<p><a href="/events/upcoming">View upcoming events &rarr;</a></p>

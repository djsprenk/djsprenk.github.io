---
layout: layouts/base.njk
title: Events
---

<h1>Events</h1>

<h2>Upcoming</h2>
<ul class="card-stack">
  {% for event in events | upcomingEvents %}
  <li class="card{% if event.image %} card--horizontal{% endif %}{% if event.url %} card--clickable{% endif %}">
    {% if event.url %}
    <a href="{{ event.url }}" class="card-overlay" target="_blank" rel="noopener" aria-label="{{ event.name }}"></a>
    {% endif %}
    <div class="card-body">
      <p class="card-date">{{ event.startDate }}{% if event.endDate %} – {{ event.endDate }}{% endif %}</p>
      <h3 class="card-title">{{ event.name }}</h3>
      <p class="card-location">{{ event.location }}</p>
    </div>
    {% if event.image %}
    <img src="{{ event.image }}" alt="{{ event.imageAlt or event.name }}" class="card-image">
    {% endif %}
  </li>
  {% endfor %}
</ul>

<h2>Previous</h2>
{% set milestonesByYear = milestones | indexByYear %}
<div class="timeline">
  {% for group in events | previousEventsByYear %} {% set yearMilestone = milestonesByYear[group.year] %}
  <div class="timeline-year">
    <div class="timeline-year-label">{{ group.year }}</div>
    {% if yearMilestone %}
    <ul class="timeline-achievements">
      {% for achievement in yearMilestone.achievements %}
      <li class="timeline-achievement">{{ achievement }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    <ul class="timeline-events">
      {% for event in group.events %}
      <li class="timeline-event">
        <span class="timeline-event-name"
          >{% if event.url %}<a href="{{ event.url }}" target="_blank" rel="noopener">{{ event.name }}</a>{% else %}{{
          event.name }}{% endif %}{% if event.note %} <em>· {{ event.note }}</em>{% endif %}</span
        >
        <span class="timeline-event-meta">{{ event.location }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</div>

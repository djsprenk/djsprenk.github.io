---
layout: layouts/base.njk
title: Home
wideLayout: true
---

<section class="hero">
  <h1 class="brand-text">DJ Sprenk</h1>
  <p>{{ site.tagline }}</p>
  <div class="hero-actions">
    <a href="/events" class="btn btn-primary">Upcoming Events</a>
    <a href="/contact" class="btn btn-outline">Book Me</a>
  </div>
</section>

<section class="section">
  <h2>Upcoming Events</h2>
  <ul class="card-grid">
    {% for event in events | upcomingEvents %}
    <li class="card{% if event.url %} card--clickable{% endif %}">
      {% if event.url %}
      <a href="{{ event.url }}" class="card-overlay" target="_blank" rel="noopener" aria-label="{{ event.name }}"></a>
      {% endif %}
      {% if event.image %}
      <img src="{{ event.image }}" alt="{{ event.imageAlt or event.name }}" class="card-image">
      {% endif %}
      <p class="card-date">{{ event.startDate }}{% if event.endDate %} – {{ event.endDate }}{% endif %}</p>
      <h3 class="card-title">{{ event.name }}</h3>
      <p class="card-location">{{ event.location }}</p>
    </li>
    {% endfor %}
  </ul>
  <p><a href="/events">See all events &rarr;</a></p>
</section>

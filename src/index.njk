---
layout: layouts/base.njk
title: Home
wideLayout: true
---

<section class="hero">
  <h1 class="brand-text">DJ Sprenk</h1>
  <p>{{ site.tagline }}</p>
  <div class="hero-actions">
    <a href="/events/upcoming" class="btn btn-primary">Upcoming Events</a>
    <a href="/contact" class="btn btn-outline">Book Me</a>
  </div>
</section>

<section class="section">
  <h2>Upcoming Events</h2>
  <ul class="card-grid">
    {% for event in events | upcomingEvents %}
    <li class="card">
      <p class="card-date">{{ event.startDate }}{% if event.endDate %} – {{ event.endDate }}{% endif %}</p>
      <h3 class="card-title">{{ event.name }}</h3>
      <p class="card-location">{{ event.location }}</p>
      {% if event.url %}
      <a href="{{ event.url }}" class="card-link" target="_blank" rel="noopener">Details &rarr;</a>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  <p><a href="/events">See all events &rarr;</a></p>
</section>

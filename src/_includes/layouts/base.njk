<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} – {% endif %}DJ Sprenk</title>
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/tokens.css" />
    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/base.css" />
    <link rel="stylesheet" href="/assets/css/components/hero.css" />
    <link rel="stylesheet" href="/assets/css/components/cards.css" />
    <link rel="stylesheet" href="/assets/css/components/forms.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/brands.min.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-logo brand-text">DJ Sprenk</a>

        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <button class="nav-close" aria-label="Close navigation" hidden>&times;</button>

        <ul class="nav-links">
          <li class="has-submenu">
            <a href="/about">About</a>
            <ul class="submenu">
              <li><a href="/services">Services</a></li>
              <li><a href="/policies">Policies</a></li>
              <li><a href="/media-kit">Media Kit</a></li>
            </ul>
          </li>
          <li><a href="/music">Music</a></li>
          <li><a href="/courses">Courses</a></li>
          <li><a href="/events">Events</a></li>
          <li class="has-submenu">
            <a href="/contact">Contact</a>
            <ul class="submenu">
              <li><a href="/contact">Message Me</a></li>
              <li><a href="/feedback">Submit Feedback</a></li>
            </ul>
          </li>
        </ul>
      </nav>
    </header>

    <main{% if splashPage %} class="splash"{% elif wideLayout %} class="wide"{% endif %}>{{ content | safe }}</main>

    <footer>
      <ul class="footer-social">
        <li><a href="{{ site.social.mixcloud }}" target="_blank" rel="noopener" aria-label="Mixcloud"><i class="fa-brands fa-mixcloud" aria-hidden="true"></i></a></li>
        <li><a href="{{ site.social.soundcloud }}" target="_blank" rel="noopener" aria-label="SoundCloud"><i class="fa-brands fa-soundcloud" aria-hidden="true"></i></a></li>
        <li><a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa-brands fa-instagram" aria-hidden="true"></i></a></li>
        <li><a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa-brands fa-facebook" aria-hidden="true"></i></a></li>
        <li><a href="{{ site.social.patreon }}" target="_blank" rel="noopener" aria-label="Patreon"><i class="fa-brands fa-patreon" aria-hidden="true"></i></a></li>
        <li class="footer-copyright">&copy; {% year %} DJ Sprenk</li>
      </ul>
    </footer>

    <script src="/assets/js/nav.js"></script>
  </body>
</html>

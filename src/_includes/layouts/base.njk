<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} – {% endif %}DJ Sprenk</title>
    <meta name="description" content="{{ description if description else site.tagline }}" />
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/tokens.css" />
    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/base.css" />
    <link rel="stylesheet" href="/assets/css/components/hero.css" />
    <link rel="stylesheet" href="/assets/css/components/cards.css" />
    <link rel="stylesheet" href="/assets/css/components/forms.css" />
  </head>
  <body{% if splashPage %} class="splash-page"{% endif %}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
      <nav aria-label="Main">
        <a href="/" class="nav-logo brand-text">DJ Sprenk</a>

        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <button class="nav-close" aria-label="Close navigation" hidden>&times;</button>

        <ul class="nav-links">
          <li class="has-submenu">
            <a href="/about" aria-haspopup="true" aria-expanded="false">About</a>
            <ul class="submenu" role="menu">
              <li role="none"><a href="/services" role="menuitem">Services</a></li>
              <li role="none"><a href="/policies" role="menuitem">Policies</a></li>
              <li role="none"><a href="/media-kit" role="menuitem">Media Kit</a></li>
            </ul>
          </li>
          <li><a href="/music">Music</a></li>
          <li><a href="/courses">Courses</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main id="main-content"{% if splashPage %} class="splash"{% elif wideLayout %} class="wide"{% endif %}>{{ content | safe }}</main>

    <footer>
      <ul class="footer-links">
        <li><a href="{{ site.social.mixcloud }}" target="_blank" rel="noopener" aria-label="Mixcloud, opens in new tab">{% icon "mixcloud" %}</a></li>
        <li><a href="{{ site.social.soundcloud }}" target="_blank" rel="noopener" aria-label="SoundCloud, opens in new tab">{% icon "soundcloud" %}</a></li>
        <li><a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram, opens in new tab">{% icon "instagram" %}</a></li>
        <li><a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook, opens in new tab">{% icon "facebook" %}</a></li>
        <li><a href="{{ site.social.patreon }}" target="_blank" rel="noopener" aria-label="Patreon, opens in new tab">{% icon "patreon" %}</a></li>
        <li class="footer-copyright">&copy; {% year %} <span style="font-family: var(--font-display); text-transform: uppercase;">DJ Sprenk</span></li>
      </ul>
    </footer>

    <script src="/assets/js/nav.js"></script>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} – {% endif %}DJ Sprenk</title>
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/tokens.css" />
    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/base.css" />
    <link rel="stylesheet" href="/assets/css/components/hero.css" />
    <link rel="stylesheet" href="/assets/css/components/cards.css" />
    <link rel="stylesheet" href="/assets/css/components/forms.css" />
  </head>
  <body{% if splashPage %} class="splash-page"{% endif %}>
    <header>
      <nav>
        <a href="/" class="nav-logo brand-text">DJ Sprenk</a>

        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <button class="nav-close" aria-label="Close navigation" hidden>&times;</button>

        <ul class="nav-links">
          <li class="has-submenu">
            <a href="/about">About</a>
            <ul class="submenu">
              <li><a href="/services">Services</a></li>
              <li><a href="/policies">Policies</a></li>
              <li><a href="/media-kit">Media Kit</a></li>
            </ul>
          </li>
          <li><a href="/music">Music</a></li>
          <li><a href="/courses">Courses</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main{% if splashPage %} class="splash"{% elif wideLayout %} class="wide"{% endif %}>{{ content | safe }}</main>

    <footer>
      <ul class="footer-social">
        <li><a href="{{ site.social.mixcloud }}" target="_blank" rel="noopener" aria-label="Mixcloud">{% include "icons/mixcloud.svg" %}</a></li>
        <li><a href="{{ site.social.soundcloud }}" target="_blank" rel="noopener" aria-label="SoundCloud">{% include "icons/soundcloud.svg" %}</a></li>
        <li><a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% include "icons/instagram.svg" %}</a></li>
        <li><a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% include "icons/facebook.svg" %}</a></li>
        <li><a href="{{ site.social.patreon }}" target="_blank" rel="noopener" aria-label="Patreon">{% include "icons/patreon.svg" %}</a></li>
        <li class="footer-copyright">&copy; {% year %} <span style="font-family: var(--font-display); text-transform: uppercase;">DJ Sprenk</span></li>
      </ul>
    </footer>

    <script src="/assets/js/nav.js"></script>
  </body>
</html>
